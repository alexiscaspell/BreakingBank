# Build Android APK via expo prebuild + Gradle (debug APK by default).
FROM node:24-bookworm

ARG EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
ARG EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
ARG EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
ARG BUILD_TYPE=release
ENV EXPO_PUBLIC_API_URL=${EXPO_PUBLIC_API_URL}
ENV EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=${EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID}
ENV EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=${EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID}
ENV CI=1
ENV EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1
ENV ANDROID_HOME=/opt/android-sdk
ENV ANDROID_SDK_ROOT=/opt/android-sdk
ENV PATH="${PATH}:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools"

RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-17-jdk-headless \
    wget \
    unzip \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p ${ANDROID_HOME}/cmdline-tools \
    && wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -O /tmp/cmdline-tools.zip \
    && unzip -q /tmp/cmdline-tools.zip -d ${ANDROID_HOME}/cmdline-tools \
    && mv ${ANDROID_HOME}/cmdline-tools/cmdline-tools ${ANDROID_HOME}/cmdline-tools/latest \
    && rm /tmp/cmdline-tools.zip \
    && yes | sdkmanager --licenses \
    && sdkmanager "platform-tools" "platforms;android-35" "build-tools;35.0.0"

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

RUN npx expo prebuild --platform android --no-install

# Release builds embed the JS bundle; sign with debug keystore for sideloading.
RUN printf '\nandroid {\n    buildTypes {\n        release {\n            signingConfig signingConfigs.debug\n        }\n    }\n}\n' >> android/app/build.gradle

# Allow HTTP to local/dev API (release manifest does not inherit debug cleartext flags).
RUN mkdir -p android/app/src/main/res/xml \
    && cp /app/network_security_config.xml android/app/src/main/res/xml/network_security_config.xml \
    && sed -i 's/<application/<application android:networkSecurityConfig="@xml\/network_security_config" android:usesCleartextTraffic="true"/' android/app/src/main/AndroidManifest.xml

WORKDIR /app/android

RUN if [ "$BUILD_TYPE" = "release" ]; then \
      ./gradlew assembleRelease --no-daemon; \
    else \
      cd .. && npx expo export:embed --eager --platform android --dev false && cd android && \
      ./gradlew assembleDebug --no-daemon; \
    fi

RUN mkdir -p /output \
    && if [ "$BUILD_TYPE" = "release" ]; then \
      cp app/build/outputs/apk/release/app-release.apk /output/breakingbank-release.apk; \
    else \
      cp app/build/outputs/apk/debug/app-debug.apk /output/breakingbank-debug.apk; \
    fi

CMD ["sh", "-c", "cp /output/*.apk /out/ 2>/dev/null || true && ls -la /output/"]
